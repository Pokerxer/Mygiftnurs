# MyGiftNurs Backend Environment Variables

# Server
NODE_ENV=development
PORT=9000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/mygiftnurs

# JWT & Auth
JWT_SECRET=your-super-secret-jwt-token-change-in-production
SESSION_SECRET=your-super-secret-session-token-change-in-production

# Cloudinary (images saved to "mygiftnurs" folder)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:3000

# Email
EMAIL_FROM=noreply@mygiftnurs.com

# Paystack (optional)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
